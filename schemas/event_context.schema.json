{
  "_description": "build_event_context() output — consumed by work_query, responsibility, context_builder",
  "_source": "skills/memory/event_search.py:build_event_context()",
  "required": ["title", "people"],
  "properties": {
    "title":       {"type": "string"},
    "executor":    {"type": ["string", "null"], "_note": "resolved executor from event detail (Phase 1.7.7-C)"},
    "people":      {"type": "object", "keys": {
      "owner":     {"type": "array", "items": "string", "_note": "from entities[].name (formerly detail.owners)"},
      "executors": {"type": "array", "items": "string", "_note": "from detail.participants"},
      "report_to": {"type": "array", "items": "string", "_note": "from detail.report_to"}
    }},
    "time":        {"type": "object", "keys": {"start": "string","deadline": "string"}},
    "tasks":       {"type": "array", "items": {"content": "string","actions": "array"}},
    "constraints": {"type": "array", "items": "string"},
    "evidence":    {"type": "array", "items": "string"},
    "report_to":   {"type": "array", "items": "string"},
    "source":      {"type": "string"},
    "ai_content":  {"type": "array", "_note": "Phase 1.7.7-C: from event_detail.ai_content, items match content_extraction.schema"}
  },
  "_reserved": {},
  "consumers": [
    "skills/work/work_query.py:_search_events_for_person()",
    "skills/work/responsibility.py:resolve()",
    "skills/routing/context_builder.py:build_work_context()",
    "skills/memory/event_context.py:get_related_event_context()"
  ],
  "known_drift": [
    "FIXED: work_query.py read ctx['participants'] which was never emitted by build_event_context()"
  ]
}
