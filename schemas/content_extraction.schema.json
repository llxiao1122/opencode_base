{
  "_description": "AI Content Extraction output — produced by skills/extract/ai_content_extractor.py, consumed by build_event_context() and work_view",
  "_source": "skills/extract/ai_content_extractor.py",
  "_phase": "1.7.7-B",
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "array",
      "items": {
        "required": ["section_id", "section_title", "facts", "actions", "constraints"],
        "properties": {
          "section_id": {
            "type": "string",
            "pattern": "^S[0-9]+$",
            "_example": "S3"
          },
          "section_title": {
            "type": "string",
            "_example": "现场规范"
          },
          "facts": {
            "type": "array",
            "items": {
              "required": ["text", "source_text"],
              "properties": {
                "text": {
                  "type": "string",
                  "_note": "精简后的事实陈述"
                },
                "source_text": {
                  "type": "string",
                  "_note": "原文原文，verbatim"
                }
              }
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "required": ["text", "type", "source_text", "source_section_id", "confidence"],
              "properties": {
                "text": {
                  "type": "string",
                  "_note": "以动词开头的可执行指令"
                },
                "type": {
                  "type": "string",
                  "enum": ["execute", "coordinate", "confirm", "prepare"],
                  "_note": "execute=亲自执行, coordinate=协调安排, confirm=确认回复, prepare=准备"
                },
                "source_text": {
                  "type": "string",
                  "_note": "原文原文，verbatim"
                },
                "source_section_id": {
                  "type": "string",
                  "_note": "来源 section，如 S3"
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "required": ["text", "type", "source_text", "source_section_id", "confidence"],
              "properties": {
                "text": {
                  "type": "string",
                  "_note": "限制/禁止/要求"
                },
                "type": {
                  "type": "string",
                  "enum": ["prohibition", "requirement", "deadline", "condition"],
                  "_note": "prohibition=严禁/不得/禁止, requirement=须/需/应, deadline=时间限制, condition=前置条件"
                },
                "source_text": {
                  "type": "string",
                  "_note": "原文原文，verbatim"
                },
                "source_section_id": {
                  "type": "string",
                  "_note": "来源 section"
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "notes": {
            "type": "array",
            "items": {"type": "string"},
            "_note": "补充关注信息"
          }
        }
      }
    }
  },
  "consumers": [
    "skills/memory/event_search.py:build_event_context()",
    "skills/work/work_view.py:build_work_view()",
    "skills/work/responsibility.py:resolve()",
    "skills/guard/sanitizer.py:sanitize_ai_content()"
  ],
  "semantic_validators": [
    "validate_action: reject if text starts with 预计/可能/据/发布/收到/显示",
    "validate_constraint: reject if text contains 应知应会/应急预案/应急响应",
    "validate_fact: reject if text starts with action verbs (执行/安排/完成...)"
  ]
}
