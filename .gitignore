Knowledge/**/*.pdf
Knowledge/**/*.pptx
Knowledge/**/*.docx
Knowledge/**/*.xlsx
Knowledge/**/*.xls
Knowledge/**/*.doc

# Virtual env
.venv/

# Archive
.archive/

