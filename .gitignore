# Runtime data store
state/

# Import history files (user data, large)
files/*.rtf
files/*.txt
files/*.doc
files/*.docx

# User observation logs (runtime)
memory/observations/2026-07-19.md

# Generated profile (runtime)
memory/values_profile.json

# User-level opencode config (env-specific, not tracked)
~/.config/opencode/

# Project-level opencode config (has env-specific secrets)
.opencode/opencode.jsonc
