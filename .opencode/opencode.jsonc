{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "gemini": {
      "name": "Google Gemini",
      "options": {
        "baseURL": "https://generativelanguage.googleapis.com/v1beta/openai",
        "apiKey": "{env:GEMINI_API_KEY}",
        "model": "gemini-2.0-flash"
      }
    }
  }
}