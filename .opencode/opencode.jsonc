{
  "$schema": "https://opencode.ai/config.json",
  // ============================================================
  // 项目级配置 — 与代码一起同步到 GitHub
  // 放所有环境通用的 MCP 工具定义和能力声明
  // 不要放密钥、API地址等环境相关配置
  // ============================================================

  "provider": {
    "deepseek": {
      "options": {
        "baseURL": "https://api.deepseek.com",
        // 密钥已移至环境变量 DEEPSEEK_API_KEY / LLM_API_KEY
      }
    }
  },

  "mcp": {
    // 项目专属 MCP — 本地和 VPS 都需要的能力
    // 示例：如果需要连接项目数据库的工具，放这里
    // "project-db": {
    //   "type": "remote",
    //   "url": "${PROJECT_DB_MCP_URL}",
    //   "headers": {
    //     "Authorization": "Bearer ${PROJECT_DB_MCP_TOKEN}"
    //   }
    // }
  },
}
